{
  "manifest_version": 3,
  "name": "Clipboard",
  "version": "1.0.2",
  "description": "Local-first text snippets. Save, search, categorize, and copy — no account or cloud.",
  "homepage_url": "https://github.com/shubhamgorule/clipboard/blob/main/docs/privacy-policy.html",
  "permissions": ["storage"],
  "icons": {
    "16": "store/icons/icon16.png",
    "48": "store/icons/icon48.png",
    "128": "store/icons/icon128.png"
  },
  "action": {
    "default_title": "Clipboard",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "store/icons/icon16.png",
      "48": "store/icons/icon48.png",
      "128": "store/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
